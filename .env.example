# YouTube Data API (required for --source api)
YOUTUBE_API_KEY=your_key_here

# AI Provider for categorization (pick one)
# Option 1: Claude CLI (default, supports Chrome integration)
AI_PROVIDER=claude-cli

# Option 2: Anthropic API (direct, no CLI needed)
# ANTHROPIC_API_KEY=your_key_here
# AI_PROVIDER=anthropic

# Option 3: OpenAI API
# OPENAI_API_KEY=your_key_here
# AI_PROVIDER=openai

# Option 4: OpenCode CLI (no Chrome integration)
# AI_PROVIDER=opencode-cli

# Option 5: Codex CLI (no Chrome integration)
# AI_PROVIDER=codex-cli
